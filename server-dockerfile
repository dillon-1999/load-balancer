# Build stage
FROM golang:1.26.3-alpine3.22 AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY server/*.go ./
RUN go build -o hello-server .

# Final stage
FROM alpine:3.22
WORKDIR /app
COPY --from=builder /app/hello-server ./hello-server
EXPOSE 8080
ENTRYPOINT ["/app/hello-server"]
